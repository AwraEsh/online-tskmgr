# Bot Configuration Example
# Copy this file to .env and fill in your actual tokens
# NEVER commit the .env file to version control!

# =============================================================================
# REQUIRED: Bot Tokens
# =============================================================================
# Get these from @BotFather on Bale and Telegram

# Bale Bot Token (from @BotFather on Bale)
BALE_BOT_TOKEN=your_bale_bot_token_here

# Telegram Bot Token (from @BotFather on Telegram)
TG_BOT_TOKEN=your_telegram_bot_token_here

# =============================================================================
# REQUIRED: Chat IDs
# =============================================================================
# These are YOUR user/chat IDs where the bot will send messages
# To get your chat ID:
# 1. Send a message to your bot
# 2. Visit: https://api.telegram.org/bot<YOUR_TELEGRAM_TOKEN>/getUpdates
# 3. Look for "chat":{"id":123456789} in the response

# Your Bale chat ID (where bot sends Bale messages)
BALE_CHAT_ID=your_bale_chat_id_here

# Your Telegram chat ID (where bot sends Telegram messages)
TG_CHAT_ID=your_telegram_chat_id_here

# =============================================================================
# OPTIONAL: Bot Settings (can also be set in bot.py)
# =============================================================================
# Uncomment and modify these if you want to override defaults in bot.py

# CPU temperature threshold for thermal alerts (default: 90)
# ALERT_THRESHOLD=90

# Update interval in seconds — always fixed (default: 3)
# INTERVAL_NORMAL=3
